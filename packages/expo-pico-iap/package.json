{
  "name": "expo-pico-iap",
  "version": "0.1.0",
  "description": "PICO store in-app purchase APIs for Expo apps.",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/src/index.js",
      "require": "./build/src/index.js",
      "types": "./build/src/index.d.ts"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./plugin": {
      "import": "./plugin/build/src/withPicoIap.js",
      "require": "./plugin/build/src/withPicoIap.js",
      "types": "./plugin/build/src/withPicoIap.d.ts"
    }
  },
  "scripts": {
    "build": "expo-module build",
    "build:plugin": "tsc --project plugin/tsconfig.json",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "jest --config jest.config.js",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "expo",
    "pico",
    "iap",
    "in-app-purchase",
    "pico-store"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mikevocalz/expo-pico.git",
    "directory": "packages/expo-pico-iap"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@expo-pico/platform-service-common": "*"
  },
  "devDependencies": {
    "@expo/config-plugins": "~55.0.8",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.14",
    "expo": "~55.0.17",
    "expo-modules-core": "~2.3.0",
    "expo-module-scripts": "~55.0.2",
    "expo-pico-core": "*",
    "jest": "^30.3.0",
    "react-native": "0.84.1",
    "ts-jest": "^29.4.9",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "expo": ">=55.0.0",
    "expo-pico-core": ">=0.1.0",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": false
    },
    "expo-pico-core": {
      "optional": false
    }
  },
  "files": [
    "LICENSE",
    "build",
    "android",
    "plugin/build",
    "app.plugin.js",
    "expo-module.config.json"
  ],
  "homepage": "https://github.com/mikevocalz/expo-pico/tree/main/packages/expo-pico-iap",
  "bugs": "https://github.com/mikevocalz/expo-pico/issues"
}
