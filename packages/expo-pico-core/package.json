{
  "name": "@expo-pico/core",
  "version": "0.2.0",
  "description": "Expo config plugin and runtime module for PICO OS 6 XR devices.",
  "main": "build/src/index.js",
  "types": "build/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./build/src/index.js",
      "require": "./build/src/index.js",
      "types": "./build/src/index.d.ts"
    },
    "./app.plugin.js": "./app.plugin.js",
    "./plugin": {
      "import": "./plugin/build/withPico.js",
      "require": "./plugin/build/withPico.js",
      "types": "./plugin/build/withPico.d.ts"
    },
    "./plugin/viro": {
      "import": "./plugin/build/viro/index.js",
      "require": "./plugin/build/viro/index.js",
      "types": "./plugin/build/viro/index.d.ts"
    }
  },
  "bin": {
    "expo-pico-doctor": "./cli/build/doctor.js"
  },
  "scripts": {
    "build": "expo-module build",
    "build:plugin": "tsc --project plugin/tsconfig.json",
    "build:cli": "tsc --project cli/tsconfig.json && chmod +x cli/build/doctor.js",
    "clean": "expo-module clean",
    "lint": "expo-module lint",
    "test": "jest --config jest.config.js",
    "prepare": "expo-module prepare",
    "prepublishOnly": "expo-module prepublishOnly",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "expo",
    "expo-pico",
    "pico",
    "pico-os",
    "xr",
    "spatial",
    "vr"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mikevocalz/expo-pico.git",
    "directory": "packages/expo-pico-core"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "expo": "~56.0.12",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@expo/config-plugins": "~56.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.0.0",
    "@types/react": "~19.2.14",
    "expo": "~56.0.12",
    "expo-module-scripts": "~56.0.2",
    "jest": "^29.7.0",
    "react-native": "^0.86.0",
    "ts-jest": "^29.4.9",
    "typescript": "~6.0.3"
  },
  "peerDependencies": {
    "expo": "~56.0.12",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "expo": {
      "optional": false
    }
  },
  "files": [
    "LICENSE",
    "build",
    "android",
    "cli/build",
    "plugin/build",
    "plugin/assets",
    "app.plugin.js",
    "expo-module.config.json"
  ],
  "homepage": "https://github.com/mikevocalz/expo-pico/tree/main/packages/expo-pico-core",
  "bugs": "https://github.com/mikevocalz/expo-pico/issues"
}
