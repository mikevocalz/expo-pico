node_modules/
build/
dist/
*.tsbuildinfo
.expo/
*.log
.DS_Store
*.local
plugin/build/
cli/build/
.turbo/

# Stray tsc emit — if a tsconfig ever misroots its outDir, catch it
# before it gets committed alongside .ts sources.
packages/*/plugin/src/**/*.js
packages/*/plugin/src/**/*.d.ts
packages/*/cli/src/**/*.js
packages/*/cli/src/**/*.d.ts
packages/*/src/**/*.js
packages/*/src/**/*.d.ts
!packages/__jest_stubs__/**/*.js

# CNG-generated native projects (example app only)
# Do NOT ignore packages/*/android/ — those contain library source code
example/android/
example/ios/

# Phase N — postinstall-downloaded demo glTF. Every checkout regenerates
# via `example/scripts/download-demo-model.js`. Skippable via
# EXPO_PICO_SKIP_DEMO_MODEL=1.
example/assets/models/pico-demo.glb

# PICO SDK AARs — proprietary, must be downloaded manually.
# See vendor/pico-sdk/README.md for instructions.
vendor/pico-sdk/*.aar

# Local tooling / agent state (not source, do not commit)
.claude/
.vscode/

# Per-package gradle daemon caches that occasionally leak into the
# package tree when running `./gradlew assemble*` from a consuming app.
packages/*/android/.gradle/

# patch-package error dumps (auto-generated on failed npm install)
patch-package-error.json
patch-package-error.json.gz
.vendor/

# env files with PICO credentials — never commit
.env
.env.local
.env.*.local

# Internal/working docs — keep local, not published
ARCHITECTURE.md
RELEASING.md
docs/DEVICE-TESTING-REQUIRED.md
docs/PRODUCTION-READINESS.md
docs/VIRO-ON-PICO.md
docs/example/
docs/release/
docs/validation/
.changeset/pico-swan-plus-phases-a-through-f.md
